alias rm='rm -i'
alias ll='ls -l -h'
alias df="df -h"
alias lt='ls --human-readable --size -1 -S --classify'
alias count_files='find . -type f | wc -l'
alias ..="cd .."
alias pr="cd ~/Documents/Projects"

#---------------------------------------Git-----------------------------------------------#
alias gc="git checkout"
alias gundo="git reset HEAD~1 --mixed"
alias gitmail='git config user.email "kopkayan@outlook.cz"'
