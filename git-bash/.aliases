alias ls='ls -F --color=auto --show-control-chars'
alias tree="find . -print | sed -e 's;[^/]*/;|--;g' -e 's;--|;  |;g'"

alias chrome-no-cors='"C:\Program Files\Google\Chrome\Application\chrome.exe" --disable-web-security --user-data-dir="C:\chrome_dev"'
alias firefox-no-cors='"C:\Program Files\Mozilla Firefox\firefox.exe" --disable-web-security'
alias edit-hosts='powershell -Command "Start-Process \"C:\Program Files\Sublime Text\sublime_text.exe\" -ArgumentList \"C:\Windows\System32\drivers\etc\hosts\" -Verb RunAs"'

#----------------------------------------Kubernetes----------------------------------------#
alias kube:dev2='export KUBECONFIG=~/.kube/dev2-config.yaml && kubectl config current-context'
alias kube:stage='export KUBECONFIG=~/.kube/stage-config.yaml && kubectl config current-context'
alias kube:local='unset KUBECONFIG && kubectl config current-context'

#----------------------------------------ICEWARP-------------------------------------------#
alias iw:compose="cd /c/Users/janxh/Documents/Projects/icewarp/api-service && docker compose up"
alias iw:api="cd /c/Users/janxh/Documents/Projects/icewarp/api-service && npm run dev"
alias iw:mergeapi='cd ~/Documents/Projects/icewarp/public-api-definition && npm run merge && mv merged.yaml ../api-service'
